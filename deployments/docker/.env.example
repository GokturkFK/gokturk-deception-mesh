POSTGRES_USER=gokturk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gokturk

# En az 32 byte, rastgele. Örn: openssl rand -hex 32
HMAC_KEY=change-me-32-byte-min

# APP-3 auth (opsiyonel ama önerilir) — POST /api/v1/traps (provision) bu token'ı ister.
# Boş bırakılırsa provision KORUMASIZ kalır (yalnızca air-gapped/geliştirme için).
# Rastgele üret: openssl rand -hex 32
OPERATOR_TOKEN=
# read-only rol: okuma yapabilir, provision denerse 403. Şimdilik opsiyonel.
READONLY_TOKEN=

# APP-8 bildirim fan-out (opsiyonel) — boş bırakılırsa ilgili kanal devre dışı kalır.
# SIEM_SYSLOG_ADDR docker-compose.yml içinde siem-sink:514 olarak zaten ayarlı.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
